@using System.Globalization

<div style="margin-bottom: 30px; padding: 10px 40px; background-color: #f5f5f5; border: 1px solid #ccc;">
    <div style="font-size: 24px; font-weight: bold; color: #555; margin-bottom: 8px; font-family: Arial, sans-serif;">
        @Label @(Unit != null ? $"({Unit})" : "")
    </div>

    <div style="position: relative;">
        @* Background track with color zones *@
        <div style="width: 100%; height: 36px; overflow: hidden; display: flex; border: 1px solid #999;">
            <div style="width: @(GreenStartPercent.ToString(CultureInfo.InvariantCulture))%; background-color: #e74c3c; height: 100%;"></div>
            <div style="width: @(GreenZoneWidth.ToString(CultureInfo.InvariantCulture))%; background-color: #2ecc71; height: 100%;"></div>
            <div style="width: @(RightRedZoneWidth.ToString(CultureInfo.InvariantCulture))%; background-color: #e74c3c; height: 100%;"></div>
        </div>

        @* Center line marker *@
        <div style="position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 2px; height: 42px; background-color: #333; z-index: 2;"></div>

        @* Value indicator - капля с значением *@
        <div style="position: absolute; top: -48px; left: @(ValuePercent.ToString(CultureInfo.InvariantCulture))%; transform: translateX(-50%); z-index: 3; display: flex; flex-direction: column; align-items: center;">
                @* Капля с числом *@
            <div style="background: linear-gradient(135deg, #333 0%, #111 100%);
                        color: #fff;
                        padding: 4px 10px;
                        border-radius: 8px;
                        font-size: 18px;
                        font-weight: bold;
                        font-family: Arial, sans-serif;
                        box-shadow: 0 3px 8px rgba(0,0,0,0.4);
                        border: 2px solid #fff;
                        min-width: 50px;
                        text-align: center;">
                @FormatCurrentValue()
            </div>
            @* Линия-указатель *@
            <div style="width: 2px; height: 8px; background: linear-gradient(to bottom, #333, #666);"></div>
            @* Треугольник внизу *@
            <div style="width: 0; height: 0; border-left: 10px solid transparent; border-right: 10px solid transparent; border-top: 14px solid #666;"></div>
        </div>

        @* Tick marks *@
        <div style="position: relative; height: 8px;">
            @foreach (var tick in TickMarks)
            {
                var percent = MapToVisualPercent(tick);
                <div style="position: absolute; left: @(percent.ToString(CultureInfo.InvariantCulture))%; top: 0; transform: translateX(-50%); width: 1px; height: 8px; background-color: #555;"></div>
            }
        </div>

        @* Labels *@
        <div style="position: relative; height: 28px;">
            @foreach (var label in TickLabels)
            {
                <span style="@GetLabelStyle(label)">
                    @FormatLabel(label.Value)
                </span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Unit { get; set; }
    [Parameter] public double Min { get; set; }
    [Parameter] public double Max { get; set; }
    [Parameter] public double Value { get; set; }
    [Parameter] public double GreenZoneStart { get; set; }
    [Parameter] public double GreenZoneEnd { get; set; }
    [Parameter] public int TickCount { get; set; } = 20;
    [Parameter] public int? DisplayPrecision { get; set; }

    private const double LeftDangerZonePercent = 15;
    private const double SafeZonePercent = 70;
    private const double RightDangerZonePercent = 15;
    private const double FullScalePercent = 100;
    private const int BaseLabelPrecision = 1;
    private const int MaxLabelPrecision = 4;

    private double Range => Max - Min;
    private double EffectiveGreenZoneStart => ClampToScale(Math.Min(GreenZoneStart, GreenZoneEnd));
    private double EffectiveGreenZoneEnd => ClampToScale(Math.Max(GreenZoneStart, GreenZoneEnd));
    private double GreenZoneCenter => EffectiveGreenZoneStart + ((EffectiveGreenZoneEnd - EffectiveGreenZoneStart) / 2);
    private double GreenZoneLeftInnerTick => EffectiveGreenZoneStart + ((GreenZoneCenter - EffectiveGreenZoneStart) / 2);
    private double GreenZoneRightInnerTick => GreenZoneCenter + ((EffectiveGreenZoneEnd - GreenZoneCenter) / 2);
    private double GreenStartPercent => LeftDangerZonePercent;
    private double GreenZoneWidth => SafeZonePercent;
    private double RightRedZoneWidth => RightDangerZonePercent;
    private double ClampedValue => ClampToScale(Value);
    private double ValuePercent => MapToVisualPercent(ClampedValue);
    private int LabelPrecision => DisplayPrecision ?? GetLabelPrecision();
    private int ValuePrecision => LabelPrecision;

    private List<double> TickMarks
    {
        get
        {
            var ticks = new List<double>();

            AddUniqueValue(ticks, Min);
            AddSegmentMidpoint(ticks, Min, EffectiveGreenZoneStart);
            AddUniqueValue(ticks, EffectiveGreenZoneStart);
            AddUniqueValue(ticks, GreenZoneLeftInnerTick);
            AddUniqueValue(ticks, GreenZoneCenter);
            AddUniqueValue(ticks, GreenZoneRightInnerTick);
            AddUniqueValue(ticks, EffectiveGreenZoneEnd);
            AddSegmentMidpoint(ticks, EffectiveGreenZoneEnd, Max);
            AddUniqueValue(ticks, Max);

            ticks.Sort();
            return ticks;
        }
    }

    private List<SliderLabel> TickLabels
    {
        get
        {
            var labels = new List<SliderLabel>();

            AddUniqueLabel(labels, Min, LabelAlignment.Start);
            AddUniqueLabel(labels, EffectiveGreenZoneStart, LabelAlignment.Center);
            AddUniqueLabel(labels, GreenZoneCenter, LabelAlignment.Center);
            AddUniqueLabel(labels, EffectiveGreenZoneEnd, LabelAlignment.Center);
            AddUniqueLabel(labels, Max, LabelAlignment.End);

            return labels
                .OrderBy(label => label.Value)
                .ToList();
        }
    }

    private double MapToVisualPercent(double value)
    {
        var clampedValue = ClampToScale(value);

        if (Range <= 0)
        {
            return FullScalePercent / 2;
        }

        if (clampedValue <= EffectiveGreenZoneStart)
        {
            return MapSegment(clampedValue, Min, EffectiveGreenZoneStart, 0, LeftDangerZonePercent);
        }

        if (clampedValue <= EffectiveGreenZoneEnd)
        {
            return MapSegment(
                clampedValue,
                EffectiveGreenZoneStart,
                EffectiveGreenZoneEnd,
                LeftDangerZonePercent,
                LeftDangerZonePercent + SafeZonePercent);
        }

        return MapSegment(
            clampedValue,
            EffectiveGreenZoneEnd,
            Max,
            LeftDangerZonePercent + SafeZonePercent,
            FullScalePercent);
    }

    private double ClampToScale(double value)
    {
        return Math.Max(Min, Math.Min(Max, value));
    }

    private int GetLabelPrecision()
    {
        return GetPrecision(TickLabelValues);
    }

    private static int GetPrecision(IEnumerable<double> sourceValues)
    {
        var values = new List<double>();
        foreach (var value in sourceValues)
        {
            AddUniqueValue(values, value);
        }

        for (var precision = BaseLabelPrecision; precision <= MaxLabelPrecision; precision++)
        {
            var formattedValues = values
                .Select(value => value.ToString($"F{precision}", CultureInfo.InvariantCulture))
                .Distinct()
                .Count();

            if (formattedValues == values.Count)
            {
                return precision;
            }
        }

        return MaxLabelPrecision;
    }

    private List<double> TickLabelValues =>
    [
        Min,
        EffectiveGreenZoneStart,
        GreenZoneCenter,
        EffectiveGreenZoneEnd,
        Max
    ];

    private static void AddUniqueValue(List<double> values, double value)
    {
        if (!ContainsApproximate(values, value))
        {
            values.Add(value);
        }
    }

    private static void AddSegmentMidpoint(List<double> values, double start, double end)
    {
        if (end <= start)
        {
            return;
        }

        AddUniqueValue(values, start + ((end - start) / 2));
    }

    private static void AddUniqueLabel(List<SliderLabel> labels, double value, LabelAlignment alignment)
    {
        if (labels.Any(label => AreClose(label.Value, value)))
        {
            return;
        }

        labels.Add(new SliderLabel(value, alignment));
    }

    private string GetLabelStyle(SliderLabel label)
    {
        var percent = MapToVisualPercent(label.Value).ToString(CultureInfo.InvariantCulture);

        return label.Alignment switch
        {
            LabelAlignment.Start =>
                $"position: absolute; left: {percent}%; transform: none; font-size: 20px; color: #555; font-family: Arial, sans-serif; white-space: nowrap;",
            LabelAlignment.End =>
                $"position: absolute; left: {percent}%; transform: translateX(-100%); font-size: 20px; color: #555; font-family: Arial, sans-serif; white-space: nowrap;",
            _ =>
                $"position: absolute; left: {percent}%; transform: translateX(-50%); font-size: 20px; color: #555; font-family: Arial, sans-serif; white-space: nowrap;"
        };
    }

    private string FormatLabel(double value)
    {
        return value.ToString($"F{LabelPrecision}", CultureInfo.InvariantCulture);
    }

    private string FormatCurrentValue()
    {
        return Value.ToString($"F{ValuePrecision}", CultureInfo.InvariantCulture);
    }

    private static bool ContainsApproximate(IEnumerable<double> values, double candidate)
    {
        return values.Any(value => AreClose(value, candidate));
    }

    private static bool AreClose(double left, double right)
    {
        return Math.Abs(left - right) < 0.000001;
    }

    private static double MapSegment(
        double value,
        double inputStart,
        double inputEnd,
        double outputStart,
        double outputEnd)
    {
        if (inputEnd <= inputStart)
        {
            return outputEnd;
        }

        var ratio = (value - inputStart) / (inputEnd - inputStart);
        var clampedRatio = Math.Max(0, Math.Min(1, ratio));

        return outputStart + ((outputEnd - outputStart) * clampedRatio);
    }

    private sealed record SliderLabel(double Value, LabelAlignment Alignment);

    private enum LabelAlignment
    {
        Start,
        Center,
        End
    }
}
