@using Final_Test_Hybrid.Services.Steps.Infrastructure.Execution.Scanning
@using Final_Test_Hybrid.Services.SpringBoot.Operator
@using Final_Test_Hybrid.Services.Common.Settings
@using Final_Test_Hybrid.Components.Engineer.Modals
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject ScannerInputOwnershipService ScannerInputOwnership
@inject OperatorAuthService OperatorAuthService
@inject AppSettingsService AppSettingsService
@implements IDisposable

<div class="admin-auth-dialog">
    @if (UseQrAuth)
    {
        <RadzenIcon Icon="qr_code_scanner" class="qr-icon" />
        <div class="instruction-text">Отсканируйте код администратора</div>
    }
    else
    {
        <div class="field-group">
            <label class="field-label">Логин</label>
            <RadzenTextBox @bind-Value="_login" Placeholder="Логин" Style="width: 100%;" />
        </div>
        <div class="field-group">
            <label class="field-label">Пароль</label>
            <RadzenPassword @bind-Value="_password" Placeholder="Пароль" Style="width: 100%;" />
        </div>
        @if (!string.IsNullOrEmpty(_validationError))
        {
            <div class="validation-error">@_validationError</div>
        }
    }

    @if (_isLoading)
    {
        <div class="loading-text">Авторизация...</div>
    }

    @if (!UseQrAuth || ShowCancelButton)
    {
        <div class="dialog-buttons">
            @if (!UseQrAuth)
            {
                <RadzenButton Text="Подтвердить"
                              Icon="check"
                              Click="@OnConfirm"
                              ButtonStyle="ButtonStyle.Primary"
                              IsBusy="_isLoading"
                              class="confirm-button" />
            }
            @if (ShowCancelButton)
            {
                <RadzenButton Text="Отмена"
                              Icon="close"
                              Click="@OnCancelAsync"
                              ButtonStyle="ButtonStyle.Light"
                              Disabled="_isLoading"
                              class="cancel-button" />
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public bool ShowCancelButton { get; set; } = true;

    [Parameter]
    public bool RequireProtectedCancel { get; set; } = true;

    [Parameter]
    public bool ReturnRepeatBypassOnCancel { get; set; }

    private bool UseQrAuth => AppSettingsService.UseAdminQrAuth;
    private readonly string _dialogKey = $"admin-auth-dialog:{Guid.NewGuid():N}";
    private bool _disposed;
    private bool _isLoading;
    private string _login = string.Empty;
    private string _password = string.Empty;
    private string _validationError = string.Empty;

    protected override void OnInitialized()
    {
        if (UseQrAuth)
        {
            ScannerInputOwnership.AcquireDialogOwner(_dialogKey, OnBarcodeScanned);
        }
    }

    private async void OnBarcodeScanned(string barcode)
    {
        try
        {
            if (_disposed) return;

            try
            {
                await InvokeAsync(() => ProcessBarcodeAsync(barcode));
            }
            catch (Exception) when (_disposed)
            {
                // Component disposed during async operation - expected
            }
        }
        catch (Exception)
        {
            //ignored
        }
    }

    private async Task ProcessBarcodeAsync(string barcode)
    {
        if (_disposed || _isLoading)
        {
            return;
        }
        await ExecuteWithLoadingAsync(() => OperatorAuthService.AuthenticateAdminByQrAsync(barcode));
    }

    private async Task OnConfirm()
    {
        _validationError = string.Empty;
        if (!ValidateFields())
        {
            return;
        }
        await ExecuteWithLoadingAsync(() => OperatorAuthService.AuthenticateAdminAsync(_login, _password));
    }

    private async Task OnCancelAsync()
    {
        if (_disposed || _isLoading)
        {
            return;
        }

        if (!await CanCancelAsync())
        {
            return;
        }

        CloseDialog(ReturnRepeatBypassOnCancel ? AdminAuthResult.RepeatBypass() : null);
    }

    private bool ValidateFields()
    {
        if (!string.IsNullOrWhiteSpace(_login) && !string.IsNullOrWhiteSpace(_password))
        {
            return true;
        }
        _validationError = "Заполните все поля";
        return false;
    }

    private Task<bool> CanCancelAsync()
    {
        return RequireProtectedCancel
            ? ShowPasswordDialogAsync()
            : Task.FromResult(true);
    }

    private async Task<bool> ShowPasswordDialogAsync()
    {
        var result = await DialogService.OpenAsync<PasswordDialog>(
            "Введите пароль",
            new Dictionary<string, object>(),
            new DialogOptions
            {
                Width = "350px",
                CloseDialogOnOverlayClick = false
            });

        return result is true;
    }

    private async Task ExecuteWithLoadingAsync(Func<Task<OperatorAuthResult>> action)
    {
        _isLoading = true;
        StateHasChanged();
        var result = await action();
        if (_disposed)
        {
            return;
        }
        _isLoading = false;
        StateHasChanged();
        HandleResult(result);
    }

    private void HandleResult(OperatorAuthResult result)
    {
        if (result.Success)
        {
            CloseWithSuccess(result);
            return;
        }
        ShowAuthError(result);
    }

    private void CloseWithSuccess(OperatorAuthResult result)
    {
        NotificationService.Notify(NotificationSeverity.Success, "Авторизация успешна");
        CloseDialog(new AdminAuthResult
        {
            Success = true,
            Username = result.Username ?? _login,
            ErrorMessage = null
        });
    }

    private void ShowAuthError(OperatorAuthResult result)
    {
        var error = result.ErrorMessage ?? "Ошибка авторизации";
        NotificationService.Notify(NotificationSeverity.Error, error);
    }

    private void CloseDialog(object? result = null)
    {
        ScannerInputOwnership.ReleaseDialogOwner(_dialogKey);
        DialogService.Close(result);
    }

    public void Dispose()
    {
        _disposed = true;
        ScannerInputOwnership.ReleaseDialogOwner(_dialogKey);
    }
}
