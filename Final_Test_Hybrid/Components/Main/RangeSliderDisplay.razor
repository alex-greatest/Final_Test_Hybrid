@using Final_Test_Hybrid.Services.Errors
@using Final_Test_Hybrid.Services.Main.Messages
@using Final_Test_Hybrid.Services.Steps.Infrastructure.Execution.Completion
@inject RangeSliderUiState RangeSliderUiState
@inject GasValveTubeDeferredErrorService GasValveTubeDeferredErrorService
@implements IDisposable

<div class="range-slider-display-container">
@if (!string.IsNullOrEmpty(RangeSliderUiState.Title))
{
    <div class="range-slider-title">@RangeSliderUiState.Title</div>
}
@if (GasValveTubeDeferredErrorService.IsMessageActive)
{
    <div class="range-slider-alert">@MessageTextResources.GasValveTubeNotConnected</div>
}
@{
    var sliders = GetSlidersForDisplay();
    var displayPrecision = GetDisplayPrecision(sliders);
}
@foreach (var data in sliders)
{
    <RangeSlider
        Label="@data.Label"
        Unit="@data.Unit"
        Min="@data.Min"
        Max="@data.Max"
        Value="@data.Value"
        GreenZoneStart="@data.GreenZoneStart"
        GreenZoneEnd="@data.GreenZoneEnd"
        TickCount="@data.TickCount"
        DisplayPrecision="@displayPrecision" />
}
</div>

@code {
    private const int BasePrecision = 2;
    private const int MaxPrecision = 4;

    /// <summary>
    /// Подписывается на событие изменения состояния слайдеров.
    /// </summary>
    protected override void OnInitialized()
    {
        RangeSliderUiState.OnStateChanged += HandleStateChanged;
        GasValveTubeDeferredErrorService.OnStateChanged += HandleStateChanged;
    }

    /// <summary>
    /// Обрабатывает изменение состояния слайдеров.
    /// </summary>
    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private List<RangeSliderDisplayData> GetSlidersForDisplay()
    {
        return RangeSliderUiState.GetActiveSliders()
            .OrderBy(kvp => kvp.Key)
            .Select(kvp => kvp.Value)
            .ToList();
    }

    private static int GetDisplayPrecision(IReadOnlyCollection<RangeSliderDisplayData> sliders)
    {
        var requiredPrecision = BasePrecision;

        foreach (var slider in sliders)
        {
            requiredPrecision = Math.Max(requiredPrecision, GetRequiredPrecision(slider));
        }

        return requiredPrecision;
    }

    private static int GetRequiredPrecision(RangeSliderDisplayData slider)
    {
        var values = new List<double>();
        var greenStart = Math.Min(slider.GreenZoneStart, slider.GreenZoneEnd);
        var greenEnd = Math.Max(slider.GreenZoneStart, slider.GreenZoneEnd);
        var greenCenter = GetGreenZoneCenter(slider);

        AddUniqueValue(values, slider.Min);
        AddUniqueValue(values, greenStart);
        AddUniqueValue(values, greenStart + ((greenCenter - greenStart) / 2));
        AddUniqueValue(values, greenCenter);
        AddUniqueValue(values, greenCenter + ((greenEnd - greenCenter) / 2));
        AddUniqueValue(values, greenEnd);
        AddUniqueValue(values, slider.Max);

        for (var precision = BasePrecision; precision <= MaxPrecision; precision++)
        {
            var formattedValues = values
                .Select(value => value.ToString($"F{precision}", System.Globalization.CultureInfo.InvariantCulture))
                .Distinct()
                .Count();

            if (formattedValues == values.Count)
            {
                return precision;
            }
        }

        return MaxPrecision;
    }

    private static double GetGreenZoneCenter(RangeSliderDisplayData slider)
    {
        var greenStart = Math.Min(slider.GreenZoneStart, slider.GreenZoneEnd);
        var greenEnd = Math.Max(slider.GreenZoneStart, slider.GreenZoneEnd);
        return greenStart + ((greenEnd - greenStart) / 2);
    }

    private static void AddUniqueValue(List<double> values, double value)
    {
        if (!values.Any(existingValue => Math.Abs(existingValue - value) < 0.000001))
        {
            values.Add(value);
        }
    }

    /// <summary>
    /// Отписывается от события при уничтожении компонента.
    /// </summary>
    public void Dispose()
    {
        RangeSliderUiState.OnStateChanged -= HandleStateChanged;
        GasValveTubeDeferredErrorService.OnStateChanged -= HandleStateChanged;
    }
}
